# Opcional: porta do servidor (padrão 3847)
PORT=3847

# Supabase — cadastros compartilhados (conta, página, pixel)
# Project Settings → API: copie URL e service_role (secret).
# Sem estas variáveis, os cadastros ficam em data/meta-assets.json (só nesta máquina).
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: timeout HTTP longo para uploads Meta (ms)
# MDM_HTTP_REQUEST_TIMEOUT_MS=900000
